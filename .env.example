# .env.example — скопируйте в .env и заполните значения

# Сервер
PORT=8080
ENVIRONMENT=development  # development | production

# База данных
DATABASE_URL=postgres://carpooling:secret@localhost:5432/carpooling?sslmode=disable

# JWT
JWT_SECRET=your-secret-key-min-32-chars-change-this
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# OSRM (роутинг)
OSRM_BASE_URL=http://router.project-osrm.org
# Для продакшна: http://your-osrm-server:5000

# Email (для верификации)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=app-password
SMTP_FROM=noreply@yourcompany.com

# Приложение
APP_BASE_URL=https://carpooling.yourcompany.com
APP_NAME=Поездки в офис

# Глобальные дефолты ограничений
DEFAULT_MAX_DETOUR_MINUTES=15
DEFAULT_MAX_DISTANCE_METERS=2000
DEFAULT_MIN_JOIN_MINUTES=30

# Переменные для Docker Compose
DB_USER=carpooling
DB_PASSWORD=secret
DB_NAME=carpooling

